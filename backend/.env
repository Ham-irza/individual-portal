# --- Security ---
SECRET_KEY=django-insecure-replace-this-with-a-real-random-string-later
DEBUG=True
# Allow everything for now to eliminate "Bad Request" errors
ALLOWED_HOSTS=hainanbuilders.com,www.hainanbuilders.com,localhost,127.0.0.1,*

# --- Email (SMTP) Configuration ---
# Hostinger Email: partner@hainancorporateservices.com
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=partner@hainancorporateservices.com
EMAIL_HOST_PASSWORD=HCSGs@123.
DEFAULT_FROM_EMAIL=partner@hainancorporateservices.com

# Frontend URL for email links
FRONTEND_URL=https://www.hainanbuilders.com

# --- CORS & JWT ---
# Allow your domain over standard HTTP
CORS_ALLOWED_ORIGINS=http://hainanbuilders.com,http://www.hainanbuilders.com,http://localhost:3000
JWT_ACCESS_MINUTES=60

# --- Using SQLite for local development ---
#Uncomment PostgreSQL settings if using PostgreSQL
PG_NAME=individual_portal
PG_USER=individual_user
PG_PASSWORD=individual_password
PG_HOST=localhost
PG_PORT=5432

# --- Production Lenience (Keep these False for now) ---
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False