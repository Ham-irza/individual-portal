# --- Security ---
SECRET_KEY=django-insecure-replace-this-with-a-real-random-string-later
DEBUG=True

# UPDATED: Added the new subdomain 
ALLOWED_HOSTS=portal.hainanbuilders.com,localhost,127.0.0.1,*

# --- Email (SMTP) Configuration ---
# Hostinger Email: partner@hainancorporateservices.com
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=partner@hainancorporateservices.com
EMAIL_HOST_PASSWORD=HCSGs@123.
DEFAULT_FROM_EMAIL=partner@hainancorporateservices.com

# UPDATED: Frontend URL for email links pointing to the new subdomain
FRONTEND_URL=https://portal.hainanbuilders.com

# --- CORS & JWT ---
# UPDATED: Allow the secure portal domain to talk to the backend
CORS_ALLOWED_ORIGINS=https://portal.hainanbuilders.com,http://localhost:3000,http://localhost:5173
JWT_ACCESS_MINUTES=60

# --- PostgreSQL Database ---
# UPDATED: These are now active and match the database we built!
PG_NAME=individual_portal
PG_USER=individual_user
PG_PASSWORD=individual_password
PG_HOST=localhost
PG_PORT=5432

# --- Production Security ---
# UPDATED: Set to True because we are securing the site with HTTPS
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False